    "eslint": "^10.0.2",
    "globals": "^17.3.0",
    "jszip": "^3.10.1",
    "lobos": "^0.10.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1",
    "vite-plugin-singlefile": "^2.3.0"
